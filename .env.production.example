# Production environment example for Aliyun ECS.
# Copy this file to .env on the server and fill real values there.
# Do not commit .env.

# Required: Node service bind address behind Nginx.
HOST=127.0.0.1

# Required: Node service port behind Nginx.
PORT=4173

# Required: persistent SQLite data directory on ECS.
DATA_DIR=/opt/afterwork-five-minutes/data

# Required when the public site uses HTTPS through Nginx.
COOKIE_SECURE=true

# Required for real DeepSeek AI. Leave empty only if you accept local fallback mode.
AI_PROVIDER=deepseek
AI_API_KEY=
DEEPSEEK_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_TIMEOUT_MS=12000

# Required if you want Baidu Cloud speech-to-text fallback.
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_DEV_PID=1537
BAIDU_CUID=afterwork-five-minutes

# Optional OpenAI-compatible speech-to-text fallback.
STT_API_KEY=
STT_BASE_URL=https://api.openai.com/v1
STT_MODEL=whisper-1
STT_TIMEOUT_MS=30000

# Optional: SQLite backup retention days.
BACKUP_KEEP_DAYS=14

# HTTP 服务配置
HOST=127.0.0.1
PORT=4173

# 可选：自定义 SQLite 数据目录。为空时使用项目内 data/。
DATA_DIR=

# DeepSeek / OpenAI-compatible AI 配置
# 推荐复制本文件为 .env 后填写；server.js 会自动加载 .env。
AI_PROVIDER=deepseek
AI_API_KEY=
DEEPSEEK_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash
AI_TIMEOUT_MS=12000

# 可选：后端语音转文字备用通道。Web Speech API 网络不可用时使用。
# 百度智能云语音识别优先级更高，适合中文短语音识别。
BAIDU_API_KEY=
BAIDU_SECRET_KEY=
BAIDU_DEV_PID=1537
BAIDU_CUID=afterwork-five-minutes

# 也支持 OpenAI-compatible /audio/transcriptions 接口。
STT_API_KEY=
STT_BASE_URL=https://api.openai.com/v1
STT_MODEL=whisper-1
STT_TIMEOUT_MS=30000

# 如果站点只通过 HTTPS 访问，可设为 true，让登录 cookie 带 Secure。
COOKIE_SECURE=false

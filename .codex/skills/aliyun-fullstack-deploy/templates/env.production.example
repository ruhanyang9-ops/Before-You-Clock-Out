# Production environment example. Copy to .env on ECS and fill real values there.
# Do not commit .env.

NODE_ENV=production
PORT=3000

# Public frontend/API URL examples. Adjust to your framework.
API_BASE_URL=https://example.com
PUBLIC_API_BASE_URL=https://example.com/api

# Required if the application uses login/session/JWT.
JWT_SECRET=replace-with-a-long-random-secret
SESSION_SECRET=replace-with-a-long-random-secret

# Database. Use only one real connection string in production.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
MYSQL_URL=mysql://USER:PASSWORD@HOST:3306/DBNAME
POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
MONGODB_URI=mongodb://USER:PASSWORD@HOST:27017/DBNAME

# Optional cache/storage/integrations.
REDIS_URL=redis://HOST:6379
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_ACCESS_KEY_SECRET=

# Optional AI/API integrations.
AI_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
